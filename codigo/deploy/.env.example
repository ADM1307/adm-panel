# Copia a .env y ajusta.
# Dominio del panel (apunta un registro A a la IP de tu VPS):
PANEL_DOMAIN=panel.atlasdigitalmark.com

# Candado del panel (opcional pero MUY recomendado en producción).
# Genera el hash con:
#   docker run --rm caddy:2.8 caddy hash-password --plaintext 'TU_PASSWORD'
PANEL_USER=adm
PANEL_PASSWORD_HASH=
